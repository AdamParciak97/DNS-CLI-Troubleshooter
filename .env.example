# Klucz API Anthropic (wymagany dla AI Summary)
ANTHROPIC_API_KEY=sk-ant-api03-twój-klucz-tutaj

# Dane logowania do dashboardu
CT_USERNAME=admin
CT_PASSWORD=zmień-to-hasło

# Klucz do podpisywania tokenów JWT (zmień na losowy ciąg)
CT_SECRET_KEY=zmień-na-losowy-ciąg-minimum-32-znaki

# Opcjonalne ustawienia
CT_DEFAULT_PROFILE=quick
CT_PORT=8080
CT_DATA_RETENTION_DAYS=90
